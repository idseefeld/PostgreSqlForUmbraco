		<None Remove="getalias-errors.playlist" />
		<None Remove="second-half-of-integration-tests.playlist" />
		<None Remove="umb.sql" />
		<None Remove="umbMain.sql" />
		<None Remove="uniqueid-errors.playlist" />
		<None Remove="upostgresql.png" />
		<None Remove="upostgresql.psd" />
		<None Remove="upostgresqlfix.png" />
	</ItemGroup>

	<ItemGroup>
		<None Include="upostgresql.png" Pack="true" PackagePath="" Visible="false" />
