<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<PackageId>Our.Umbraco.PostgreSql</PackageId>
		<VersionPrefix>17.3.0</VersionPrefix>
		<Company>-</Company>
		<Authors>Dirk Seefeld</Authors>
		<PackageIcon>uPostgresql.png</PackageIcon>
		<PackageReadmeFile>readme.md</PackageReadmeFile>
		<Product>PostgreSQL Provider for Umbraco CMS</Product>
		<PackageTags>umbraco, postgresql, community</PackageTags>
		<Copyright>Copyright © Dirk Seefeld $([System.DateTime]::Today.ToString('yyyy'))</Copyright>
		<Title>Umbraco CMS - Persistence - PostgreSQL</Title>
		<Description>Adds support for PostgreSQL to Umbraco CMS.</Description>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
		<Compile Remove="Services\PostgreSqlBatchSqlInsertProvider - Copy.cs" />
		<Compile Remove="Services\PostgreSqlDatabase.cs" />
		<Compile Remove="Services\PostgreSqlDatabaseFactory.cs" />
	</ItemGroup>

	<ItemGroup>
		<None Remove="datetime-erros.playlist" />
		<None Remove="ExecuteScalar-errors.playlist" />
		<None Remove="file-open-error.playlist" />
		<None Remove="getalias-errors.playlist" />
		<None Remove="umb.sql" />
		<None Remove="umbMain.sql" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="readme.md" Pack="true" PackagePath="\" />
		<Content Include="uPostgresql.png" Pack="true" PackagePath="" Visible="false" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Npgsql" Version="10.0.1" />
		<PackageReference Include="Umbraco.Cms.Infrastructure" Version="17.3.0--rc.preview.233.g6acb0ba" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Our.Umbraco.PostgreSql.EFCore\Our.Umbraco.PostgreSql.EFCore.pack.csproj" />
	</ItemGroup>

</Project>
